# Block postinstall/preinstall scripts from dependencies
# Primary defense against supply chain attacks like the axios compromise
ignore-scripts=true

# Reject packages published less than 3 days ago (259200 seconds)
# Catches most malicious publishes before they're detected and removed
min-release-age=259200

# Always generate and respect the lockfile
package-lock=true

# Run audit on every install
audit=true
